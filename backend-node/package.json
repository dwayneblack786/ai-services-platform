{
  "name": "oauth2-server",
  "version": "1.0.0",
  "description": "Node.js Express backend with OAuth2 authentication",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "seed:products": "ts-node src/scripts/seed-products.ts",
    "seed:prompts": "ts-node src/scripts/seed-prompt-config.ts",
    "seed:prompts:v2": "ts-node src/scripts/seed-prompt-config-v2.ts",
    "seed:templates": "ts-node src/scripts/seed-templates.ts",
    "cleanup:templates": "ts-node src/scripts/cleanup-old-templates.ts",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix"
  },
  "keywords": [
    "oauth2",
    "express",
    "typescript",
    "passport"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@langchain/community": "^1.1.4",
    "@langchain/core": "^1.1.15",
    "@langchain/openai": "^1.2.2",
    "@types/uuid": "^9.0.8",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "connect-redis": "^7.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.2.10",
    "mongodb": "^6.21.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
