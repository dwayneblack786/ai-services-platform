# Tenant-First Authentication Configuration

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai_platform

# Keycloak Base URL (all realms)
KEYCLOAK_URL=http://localhost:9999

# OIDC Client Credentials (same across all realms)
KEYCLOAK_CLIENT_ID=product-management
KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# OAuth Redirect URIs
KEYCLOAK_REDIRECT_URI=http://localhost:5000/api/auth/tenant/callback
CLIENT_URL=http://localhost:5173

# Session Configuration
SESSION_SECRET=your-session-secret-here
SESSION_MAX_AGE=86400000

# Tenant Context
# Tenant context expires after 5 minutes if user doesn't complete login
TENANT_CONTEXT_TIMEOUT=300000
