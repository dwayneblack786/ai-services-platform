# ==============================================================================
# OIDC/SSO Configuration for Product Management (Identity Provider)
# ==============================================================================

# OIDC Issuer URL (this server acts as the IdP)
OIDC_ISSUER=http://localhost:5000

# Registered Client Secrets (for confidential clients)
# Format: High-entropy secret (32+ characters recommended)
OIDC_CLIENT_SECRET_PROMPT_MGMT=your-secure-client-secret-for-prompt-management-min-32-chars

# Client Configuration
# Prompt Management Redirect URIs (comma-separated for multiple)
PROMPT_MGMT_REDIRECT_URI=http://localhost:3001/api/auth/sso/callback,http://localhost:5174/auth/sso/callback

# Product Management Frontend Redirect URI (for cross-domain SSO)
PRODUCT_MGMT_REDIRECT_URI=http://localhost:5173/auth/sso/callback

# Post-logout redirect URI
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/

# ==============================================================================
# OIDC Client Configuration (for SSO login to itself)
# ==============================================================================

# When product-management acts as a client (for cross-domain sessions)
OIDC_CLIENT_ID=product-management-frontend
OIDC_CLIENT_SECRET=  # Leave empty for public clients (SPA)
OIDC_REDIRECT_URI=http://localhost:5173/auth/sso/callback

# ==============================================================================
# Security Settings
# ==============================================================================

# JWT Secret (MUST be same across all services for token validation)
# In production, use RS256 with public/private key pair instead of HS256
JWT_SECRET=your-super-secret-jwt-key-min-64-chars-CHANGE-IN-PRODUCTION

# Session Secret
SESSION_SECRET=your-session-secret-min-32-chars

# ==============================================================================
# Production Recommendations
# ==============================================================================
# 1. Use environment-specific secrets (never commit secrets to git)
# 2. Use RS256 algorithm with public/private key pairs
# 3. Enable HTTPS in production (secure: true cookies)
# 4. Use Redis for state storage instead of in-memory
# 5. Implement rate limiting on token endpoints
# 6. Set up proper CORS policies
# 7. Monitor and log all authentication attempts
# 8. Implement token rotation and revocation strategies
