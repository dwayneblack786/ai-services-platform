{
  "name": "oauth2-server",
  "version": "1.0.0",
  "description": "Node.js Express backend with OAuth2 authentication",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node scripts/validate-startup.js && nodemon src/index.ts",
    "build": "tsc",
    "build:clean": "npm run clean && npm run build",
    "start": "node dist/index.js",
    "start:prod": "npm run build:clean && npm run start",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:e2e:voice": "jest tests/e2e/voice-streaming.e2e.test.ts --verbose",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:voice": "npm run test:e2e:voice",
    "test:voip": "jest tests/voip --verbose",
    "test:voip:simulation": "jest tests/voip/voip-simulation.test.ts --verbose",
    "test:voip:codec": "jest tests/voip/codec-test.test.ts --verbose",
    "test:orchestrator": "jest tests/orchestrator --verbose",
    "test:integration:voice": "jest tests/integration/voice-orchestrator-integration.test.ts --verbose",
    "generate:codecs": "ts-node tests/fixtures/audio/generate-codecs.ts",
    "seed:products": "ts-node src/scripts/seed-products.ts",
    "seed:prompts": "ts-node src/scripts/seed-prompt-config.ts",
    "seed:prompts:v2": "ts-node src/scripts/seed-prompt-config-v2.ts",
    "seed:templates": "ts-node src/scripts/seed-templates.ts",
    "seed:medical:prompts": "ts-node src/scripts/seed-medical-prompts.ts",
    "seed:rag:medical": "ts-node src/scripts/seed-rag-medical.ts",
    "seed:all": "npm run seed:products && npm run seed:prompts:v2 && npm run seed:templates",
    "cleanup:templates": "ts-node src/scripts/cleanup-old-templates.ts",
    "fix:tenant-ids": "ts-node src/scripts/fix-tenant-ids.ts",
    "rag:create-index": "ts-node src/scripts/create-vector-index.ts",
    "test:cache": "ts-node src/scripts/test-cache.ts",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "npm run lint:fix",
    "check": "npm run lint && npm run test",
    "validate": "npm run lint && npm run build && npm run test",
    "validate:startup": "node scripts/validate-startup.js",
    "validate:no-root-imports": "node scripts/validate-no-root-imports.js",
    "prepare": "npm run build:clean"
  },
  "keywords": [
    "oauth2",
    "express",
    "typescript",
    "passport"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@langchain/community": "^1.1.4",
    "@langchain/core": "^1.1.15",
    "@langchain/openai": "^1.2.2",
    "@sentry/node": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "@types/uuid": "^9.0.8",
    "applicationinsights": "^3.13.0",
    "axios": "^1.13.4",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.2.0",
    "connect-redis": "^7.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.2",
    "langchain": "^1.2.10",
    "mammoth": "^1.11.0",
    "mongodb": "^6.21.0",
    "mongoose": "^9.1.5",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "pkce-challenge": "^4.1.0",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.13",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-local": "^1.0.38",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^9.5.0",
    "nock": "^14.0.10",
    "nodemon": "^3.0.2",
    "rimraf": "^5.0.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
