# Node Environment
NODE_ENV=development
PORT=3001

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/ai_platform

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Authentication Secrets
# IMPORTANT: Generate secure random strings for production (at least 32 characters)
SESSION_SECRET=your-session-secret-here-min-32-chars
JWT_SECRET=your-jwt-secret-here-min-32-chars

# SSO Configuration (Identity Provider)
SSO_ISSUER=http://localhost:5000
SSO_TOKEN_EXPIRY=1h
SSO_REFRESH_TOKEN_EXPIRY=7d
PROMPT_MANAGEMENT_CLIENT_SECRET=your-client-secret-here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# CORS Configuration (comma-separated list)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging Configuration
LOG_LEVEL=info

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CONCURRENT_STREAMS=5
RATE_LIMIT_MESSAGES_PER_HOUR=100
RATE_LIMIT_MESSAGES_PER_DAY=1000
RATE_LIMIT_TOKENS_PER_DAY=50000

# gRPC Service URLs
GRPC_VA_SERVICE_URL=localhost:50051
GRPC_CV_SERVICE_URL=localhost:50052
GRPC_IDP_SERVICE_URL=localhost:50053

# Session Configuration
SESSION_COOKIE_MAX_AGE=86400000
SESSION_COOKIE_SECURE=false

# API Configuration
API_TIMEOUT=10000

# Circuit Breaker Configuration
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
CIRCUIT_BREAKER_TIMEOUT=60000

# Feature Flags
ENABLE_SWAGGER=true
ENABLE_METRICS=false
